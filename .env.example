# Postgres connection string. On Vercel + a managed Postgres (Neon, Supabase,
# Vercel Postgres, etc.) this is provided for you — copy it here for local dev.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# A long random string used to sign login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Used once by `npm run db:seed` to create your first admin login.
ADMIN_NAME=Anupam Kedia
ADMIN_EMAIL=anupam@anupampaints.com
ADMIN_PASSWORD=changeme123

# --- Optional: image extraction (read batch sheet photos into formulations) ---
# Get a key from console.anthropic.com -> API Keys. Costs a small amount per
# image read (pay-as-you-go on the Anthropic API, separate from any Claude.ai
# subscription).
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: Google Sheets import (raw material prices) ---
# 1. Go to console.cloud.google.com -> create a project (or use existing)
# 2. Enable the "Google Sheets API"
# 3. Create a Service Account, then create a JSON key for it
# 4. Open your Google Sheet -> Share -> paste the service account's email
#    (looks like xxxx@xxxx.iam.gserviceaccount.com) with Viewer access
# 5. From the JSON key file, copy these two values here:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
